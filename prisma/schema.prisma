// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  username          String    @unique
  passwordHash      String
  isActive          Boolean   @default(true)
  emailVerified     Boolean   @default(false)
  resetToken        String?
  resetTokenExpiry  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile           Profile?
  wallet            Wallet?
  bets              Bet[]
  leagueMemberships LeagueMember[]

  @@map("users")
}

model Profile {
  id           String    @id @default(uuid())
  userId       String    @unique
  displayName  String?
  avatarUrl    String?
  bio          String?
  preferences  Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Wallet {
  id           String    @id @default(uuid())
  userId       String    @unique
  balance      Float     @default(0)
  bonusBalance Float     @default(0)
  currency     String    @default("BRL")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id          String              @id @default(uuid())
  walletId    String
  type        TransactionType
  amount      Float
  description String?
  reference   String?
  createdAt   DateTime            @default(now())

  wallet      Wallet              @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Team {
  id          String    @id @default(uuid())
  externalId  String?   @unique
  name        String
  shortName   String
  logoUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  homeMatches Match[]   @relation("HomeTeam")
  awayMatches Match[]   @relation("AwayTeam")

  @@map("teams")
}

model Match {
  id          String      @id @default(uuid())
  externalId  String?     @unique
  homeTeamId  String
  awayTeamId  String
  kickoffTime DateTime
  status      MatchStatus @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  round       Int
  season      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  markets     Market[]
  betSelections BetSelection[]

  @@map("matches")
}

model Market {
  id          String    @id @default(uuid())
  matchId     String
  externalId  String?
  type        String
  name        String
  options     Json      // Array of { name: string, odds: number, isSuspended: boolean }
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  betSelections BetSelection[]

  @@index([matchId, type])
  @@map("markets")
}

model Bet {
  id              String          @id @default(uuid())
  userId          String
  type            BetType         @default(SINGLE)
  amount          Float
  totalOdds       Float
  potentialReturn Float
  status          BetStatus       @default(PENDING)
  settledAt       DateTime?
  wonAmount       Float?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  selections      BetSelection[]

  @@index([userId, status])
  @@map("bets")
}

model BetSelection {
  id          String              @id @default(uuid())
  betId       String
  matchId     String
  marketId    String
  optionName  String
  odds        Float
  status      BetSelectionStatus  @default(PENDING)
  createdAt   DateTime            @default(now())

  bet         Bet                 @relation(fields: [betId], references: [id], onDelete: Cascade)
  match       Match              @relation(fields: [matchId], references: [id])
  market      Market             @relation(fields: [marketId], references: [id])

  @@map("bet_selections")
}

model League {
  id          String    @id @default(uuid())
  name        String
  description String?
  code        String    @unique
  isPrivate   Boolean   @default(false)
  maxMembers  Int       @default(100)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members     LeagueMember[]

  @@map("leagues")
}

model LeagueMember {
  id        String      @id @default(uuid())
  leagueId  String
  userId    String
  role      MemberRole  @default(MEMBER)
  points    Int         @default(0)
  joinedAt  DateTime    @default(now())

  league    League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@map("league_members")
}

// Enums
enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_WON
  BONUS
  REFUND
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum BetType {
  SINGLE
  MULTIPLE
  SYSTEM
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
  PARTIALLY_WON
}

enum BetSelectionStatus {
  PENDING
  WON
  LOST
  VOID
}

enum MemberRole {
  ADMIN
  MEMBER
}