# .env.sample na raiz do projeto

# Database
DATABASE_URL="postgresql://betola:betola123@localhost:5432/betola_db"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ACCESS_SECRET="your-access-token-secret-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this-in-production"

# API Configuration
NODE_ENV="development"
PORT=3002

# Frontend URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3002"

# Email Configuration (para produção, use um serviço real como SendGrid, AWS SES, etc.)
EMAIL_FROM="noreply@betola.com"
EMAIL_SERVICE="console" # console | sendgrid | ses | smtp
SENDGRID_API_KEY=""
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10
AUTH_THROTTLE_TTL=300
AUTH_THROTTLE_LIMIT=5

# Session Configuration
SESSION_SECRET="your-session-secret-change-this-in-production"
SESSION_MAX_AGE=604800000 # 7 days in milliseconds

# Security
BCRYPT_ROUNDS=10
PASSWORD_MIN_LENGTH=6
USERNAME_MIN_LENGTH=3
USERNAME_MAX_LENGTH=20

# External APIs
ODDS_API_URL="http://localhost:8000" # URL da API Python de scraping

# FlashScore API (RapidAPI)
FLASHSCORE_API_KEY="" # Chave da FlashScore4 API (RapidAPI)
FLASHSCORE_API_HOST="flashscore4.p.rapidapi.com"
FLASHSCORE_BASE_URL="https://flashscore4.p.rapidapi.com/api/flashscore/v2"
BRASILEIRAO_TOURNAMENT_TEMPLATE_ID="Yq4hUnzQ"
BRASILEIRAO_TOURNAMENT_ID="pv7V3RRE"
BRASILEIRAO_TOURNAMENT_STAGE_ID="hdLUdQGi"
BRASILEIRAO_SEASON_ID="185"

# Cron Jobs
SYNC_MATCHES_ENABLED=true
SETTLE_BETS_ENABLED=true

# Redis (opcional, para cache e sessions)
REDIS_URL="redis://localhost:6379"

# Monitoring (opcional)
SENTRY_DSN=""
LOG_LEVEL="info"